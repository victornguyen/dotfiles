{
  "env": {
    "ENABLE_LSP_TOOL": "1"
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Write(*)",
      "Update(*)",
      "WebFetch",
      "WebSearch",
      "Bash(bd*)",
      "Bash(git diff*)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(ls*)",
      "Bash(mkdir*)",
      "Bash(mv*)",
      "Bash(touch*)",
      "Bash(chmod*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(find*)",
      "Bash(grep*)",
      "Bash(rg*)",
      "Bash(echo*)",
      "Bash(sed*)",
      "Bash(source*)",
      "Bash(curl*)",
      "Bash(make*)",
      "Bash(go*)",
      "Bash(npm*)",
      "Bash(npx*)",
      "Bash(pnpm lint*)",
      "Bash(pnpm type-check*)",
      "Bash(pnpm test*)",
      "Bash(python*)",
      "Bash(python3*)",
      "Bash(poetry*)",
      "Bash(docker*)",
      "Bash(sqlite3*)",
      "Bash(deadcode*)",
      "Bash(lsof*)",
      "Bash(pkill*)",
      "Bash(PORT=*)"
    ],
    "deny": [
      "Read(**/.env*)",
      "Bash(git commit*)",
      "Bash(git push*)"
    ]
  },
  "hooks": {
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bunx -y ccstatusline@latest --hook"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bunx -y ccstatusline@latest --hook"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0
  },
  "extraKnownMarketplaces": {
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    }
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "autoUpdates": "enabled",
  "effortLevel": "high"
}
