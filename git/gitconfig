# vim:ft=gitconfig

[user]
  name = Victor Nguyen
  email = vic.nguyen@gmail.com

[core]
  editor = nvim
  excludesfile = ~/.gitignore

[credential]
  helper = osxkeychain

[pull]
  ff = only

[push]
  default = simple
  autoSetupRemote = true

[rebase]
  autosquash = true

[commit]
  verbose = true
	gpgsign = true

[alias]
  # Adding
  a = add
  aa = add --all
  ap = add . -p
  af = add -p
  an = add . -N

  # Committing
  c = commit -v
  amend = commit --amend
  undo = reset --soft HEAD^
  uncommit = !git undo
  fixup = "!git log -n 50 --pretty=format:'%h %s' --no-merges | fzf | cut -c -7 | xargs -o git commit --fixup"

  # Branching
  b = branch
  bd = branch -d
  bm = branch -m
  co = checkout
  cob = checkout -b
  cb = cob

  # Switch to branch with fzf
  bs = !gb | xargs git checkout

  # Delete branch(es) with fzf
  bdelete = !gb | xargs git branch -d

  # Get current branch name
  branch-name = !git rev-parse --abbrev-ref HEAD

  # Pushing and pulling
  pl = pull
  ps = push
  sp = push
  force = push --force-with-lease
  publish = !git push -u origin $(git branch-name)

  # Hard reset to remote version of branch
  reset-to-remote = !git fetch && git reset --hard origin/$(git branch-name)

  # Stashing
  st = stash
  stk = stash -k
  sts = stash save
  stp = stash pop
  stl = stash list --stat --pretty='format:%C(5)%gD %C(auto)%s%n%C(11) %cr'
  st-show = stash show -p

  # Select file(s) to open in vim with fzf
  fo = !gf | xargs nvim

  # View abbreviated SHA, description, and history graph of the latest 20 commits
  l = log -n 20 --graph --abbrev-commit --pretty='format:%C(auto)%h%d %s %C(240)- %cr (%an)'

  # Show diff via diff-so-fancy
  d = diff

  # Show verbose output about tags, branches or remotes
  tags = tag -l
  branches = branch -a
  remotes = remote -v

  # Copy current SHA to system clipboard
  copysha = !git rev-parse HEAD | pbcopy

  # Find out who is currently active on the repository
  # Displays committers in descending order of number of commits
  who = shortlog --numbered --summary --email --no-merges

[pager]
  diff = delta
  show = delta

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true
  side-by-side = false
  line-numbers = true
  minus-style = "syntax #2c1f1e"
  minus-emph-style = "syntax #43302e"
  plus-style = "syntax #1f2b1f"
  plus-emph-style = "syntax #2e3f2e"
  line-numbers-minus-style = "#c4746e"
  line-numbers-plus-style = "#87a987"
  line-numbers-zero-style = "#625e5a"
  hunk-header-decoration-style = "box #393836"
  hunk-header-style = "file line-number syntax"

[color]
  ui = true

[color "diff"]
  meta = "#c4b28a"
  frag = "#8992a7" bold
  commit = "#c4b28a" bold
  old = "#c4746e" bold
  new = "#87a987" bold
  whitespace = "#c4746e" reverse

[color "diff-highlight"]
  oldNormal = "#c4746e" bold
  oldHighlight = "#c4746e" bold "#2c1f1e"
  newNormal = "#87a987" bold
  newHighlight = "#87a987" bold "#1f2b1f"

[tig]
  ignore-case = "smart-case"
  main-view-date = "relative"

[include]
  path = ~/.gitconfig-local

[gpg]
	format = ssh
[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
