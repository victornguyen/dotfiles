export EDITOR=nvim

export XDG_CONFIG_HOME="$HOME/.config"

export RIPGREP_CONFIG_PATH="${HOME}/.ripgreprc"

export GOPATH=$HOME/go
export GOBIN=$GOPATH/bin
export HOMEBREW="/opt/homebrew"

# mise shims for non-interactive shells (scripts, nvim, etc.)
export PATH="${HOME}/.local/share/mise/shims:/usr/local/sbin:${HOMEBREW}/bin:${HOMEBREW}/sbin:$PATH:${HOME}/.dotfiles/bin:$GOBIN:${HOME}/.local/bin"

# Source machine-specific local file if available
if [ -f ~/.zshenv.local ]; then
    source ~/.zshenv.local
fi
